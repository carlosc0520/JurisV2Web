# ============================================
# JURIS SEARCH FRONTEND - Variables de entorno
# ============================================
# Copia este archivo como .env y completa los valores reales
# NUNCA subir .env a GitHub

# URL base del API backend
VUE_APP_API_URL=https://api.jurissearch.com

# URL del sitio principal (para SEO, links generales — NO para archivos subidos)
VUE_APP_SITE_URL=https://jurissearch.com

# Dominio donde realmente viven los archivos subidos por FTP (fotos de perfil,
# noticias, autores, recursos) — distinto del sitio principal
VUE_APP_RESOURCES_URL=https://resources.jurissearch.com

# URL del frontend (esta app)
VUE_APP_FRONT_URL=https://side.jurissearch.com
